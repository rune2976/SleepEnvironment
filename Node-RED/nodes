        "id": "d03bdc70094012d7",
        "type": "ui_template",
        "z": "58557f04972e6afb",
        "group": "4a7323ce2340e8c6",
        "name": "temp: check in",
        "order": 3,
        "width": 0,
        "height": 0,
        "format": "<div style=\"max-width:400px;margin:auto;\">\n\n    <h2>How did you sleep?</h2>\n\n    <h3>Rate your sleep</h3>\n    <!-- Sleep score buttons -->\n    <div id=\"scoreButtons\">\n        <button ng-repeat=\"n in [1,2,3,4,5]\"\n                ng-click=\"setScore(n)\"\n                ng-class=\"{'active': score===n}\">\n            {{n}}\n        </button>\n    </div>\n\n    <br>\n\n    <!-- Disturbance input -->\n    <textarea ng-model=\"disturbance\"\n              placeholder=\"Did something disturb your sleep?\"\n              style=\"width:100%;height:80px;\"></textarea>\n\n    <br><br>\n\n    <button ng-click=\"submit()\">Submit</button>\n\n    <div ng-if=\"showSuccess\" class=\"success-box\">\n        Sleep data submitted ✓\n    </div>\n\n</div>\n\n<style>\n    #scoreButtons button {\n        margin: 5px;\n        padding: 10px 15px;\n        border: none;\n        background: #ccc;\n        cursor: pointer;\n    }\n\n    #scoreButtons button.active {\n        background: #2196F3;\n        color: white;\n    }\n\n    button {\n        width: 100%;\n        padding: 10px;\n        background: #2196F3;\n        color: white;\n        border: none;\n    }\n    .success-box {\n        margin-top: 15px;\n        padding: 10px;\n        background: #4CAF50;\n        color: white;\n        text-align: center;\n        border-radius: 5px;\n        font-weight: bold;\n    }\n</style>\n\n<script>\n    (function(scope) {\n\n    scope.score = null;\n    scope.disturbance = \"\";\n    scope.showSuccess = false;\n\n    scope.setScore = function(n) {\n        scope.score = n;\n    };\n\n    scope.submit = function() {\n\n        if (!scope.score) {\n            alert(\"Please select a sleep score\");\n            return;\n        }\n\n        // Send to Node-RED\n        scope.send({\n            payload: {\n                score: scope.score,\n                disturbances: scope.disturbance\n            }\n        });\n\n        // Show success message\n        scope.showSuccess = true;\n\n        // Auto-hide after 3 seconds\n        setTimeout(() => {\n            scope.$apply(() => {\n                scope.showSuccess = false;\n            });\n        }, 3000);\n\n        // Optional: reset form\n        scope.score = null;\n        scope.disturbance = \"\";\n\n    };\n\n})(scope);\n</script>",

     scales: {\n                            'co2-axis': {\n                                type: 'linear',\n                                position: 'left'\n                            },\n                            'sleep-axis': {\n                                type: 'linear',\n                                position: 'right',\n                                min: 1,\n                                max: 5,\n                                grid: {\n                                    drawOnChartArea: false\n                                }\n                            }\n                        }\n                    }\n                });\n            }\n\n        }, 50);\n\n    });\n\n})(scope);\n</script>",

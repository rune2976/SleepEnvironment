        "func": "// --- Get stored data ---\nlet measurements = msg.payload.measure || [];\nlet sleepSessions = msg.payload.sleep || [];\n\nif (measurements.length === 0 && sleepSessions.length === 0) {\n    node.warn(\"No data available\");\n}\n\n// --- Build daily map ---\nlet dailyMap = {};\n\n// 1. Aggregate temperature + CO2\nmeasurements.forEach(m => {\n    let d = new Date(m.timestamp);\n    d.setHours(d.getHours() - 2); \n    let date = d.toLocaleDateString(\"en-CA\");\n    \n    if (!dailyMap[date]) {\n        dailyMap[date] = {\n            tempSum: 0,\n            tempCount: 0,\n            co2Sum: 0,\n            co2Count: 0,\n            sleepScore: null\n        };\n    }\n\n    if (m.temperature !== undefined) {\n        dailyMap[date].tempSum += m.temperature;\n        dailyMap[date].tempCount += 1;\n    }\n\n    if (m.co2 !== undefined) {\n        dailyMap[date].co2Sum += m.co2;\n        dailyMap[date].co2Count += 1;\n    }\n});\n\n// 2. Ensure sleep dates exist\nsleepSessions.forEach(s => {\n    let date = s.date;\n\n    if (!dailyMap[date]) {\n        dailyMap[date] = {\n            tempSum: 0,\n            tempCount: 0,\n            co2Sum: 0,\n            co2Count: 0,\n            sleepScore: null\n        };\n    }\n});\n\n// 3. Compute averages\nfor (let date in dailyMap) {\n    let d = dailyMap[date];\n\n    d.avgTemp = d.tempCount > 0 ? d.tempSum / d.tempCount : null;\n    d.avgCO2 = d.co2Count > 0 ? d.co2Sum / d.co2Count : null;\n}\n\n// 4. Merge sleep scores\nsleepSessions.forEach(s => {\n    let date = s.date;\n    dailyMap[date].sleepScore = s.sleep_score;\n});\n\n// --- FORCE 7 DAYS ---\nlet selectedDate = flow.get(\"weeklyDate\") || flow.get(\"selectedDate\");\n\n// Start Monday\nlet base = new Date(selectedDate + \"T00:00:00\");\nlet day = base.getDay();\nlet diffToMonday = (day === 0 ? -6 : 1 - day);\nbase.setDate(base.getDate() + diffToMonday);\n\nlet result = [];\n\nfor (let i = 0; i < 7; i++) {\n    let d = new Date(base);\n    d.setDate(base.getDate() + i);\n\n    let key = d.toLocaleDateString(\"en-CA\");\n    let entry = dailyMap[key] || {};\n\n    result.push({\n        date: key,\n        avgTemp: entry.avgTemp ?? null,\n        avgCO2: entry.avgCO2 ?? null,\n        sleepScore: entry.sleepScore ?? null\n    });\n}\n\n// --- Sort ---\nresult.sort((a, b) => a.date.localeCompare(b.date));\n\n// --- Format for charts ---\nlet labels = [];\nlet tempData = [];\nlet co2Data = [];\nlet sleepData = [];\n\nresult.forEach(d => {\n\n    labels.push(\n        new Date(d.date + \"T00:00:00\")\n            .toLocaleDateString(\"en-GB\", {\n                day: \"2-digit\",\n                month: \"2-digit\"\n            })\n    );\n\n    tempData.push(d.avgTemp);\n    co2Data.push(d.avgCO2);\n    sleepData.push(d.sleepScore);\n});\n\n// --- Final payload ---\nmsg.payload = {\n    labels: labels,\n    temp: tempData,\n    co2: co2Data,\n    sleep: sleepData\n};\n\nlet monday = new Date(base);\n\nlet sunday = new Date(base);\nsunday.setDate(base.getDate() + 6);\n\nmsg.weekRange =\n    monday.toLocaleDateString(\"en-GB\") +\n    \" - \" +\n    sunday.toLocaleDateString(\"en-GB\");\n\nreturn msg;",
